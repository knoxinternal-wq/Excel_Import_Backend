PORT=5000

# Supabase (Dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
ANON_KEY=your_anon_key_here

NODE_ENV=development

# Auth: cache app_users lookups by email (speeds up repeat logins)
# AUTH_USER_CACHE_TTL_MS=600000

# Postgres (single source of truth). Supabase: Settings → Database → URI.
# Direct db: ...db.<ref>.supabase.co:5432/postgres
# Pooler (PgBouncer, port 6543): import auto-uses batched Supabase inserts; COPY path prefers direct 5432.
# DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres
#
# TLS: by default SSL uses rejectUnauthorized=false (Supabase). Set DATABASE_SSL_STRICT=1 for strict verification.
# PG_POOL_MAX=15
# PG_CONNECTION_TIMEOUT_MS=30000

# Pivot SQL: raise per-query timeout (ms). Default 600000 (10m). Use 0 to disable (not recommended on shared DBs).
# PIVOT_PG_STATEMENT_TIMEOUT_MS=900000

# Optional: skip extra COUNT(*) after GROUP BY; filtered row count is derived from group row counts (same total if grouping is exhaustive).
# PIVOT_PG_SKIP_FACT_ROW_COUNT=1

# Data tab: cache paginated JSON (default 15000 ms); exact row COUNT cache (default 120000 ms). Planned counts: DATA_USE_ESTIMATED_COUNT=1 (default).
# DATA_PAGE_CACHE_TTL_MS=15000
# DATA_COUNT_CACHE_TTL_MS=120000

# --- Large Excel import tuning (defaults tuned for high throughput) ---
# Parallel CSV shard files / COPY streams (1–8, default 4).
# IMPORT_COPY_PARALLEL=4
# Progress written to import_jobs at least every N rows during COPY (default 50000).
# IMPORT_JOB_UPDATE_EVERY_ROWS=50000
# Cancel flag checked every N data rows — not every row (default 2500).
# IMPORT_CANCEL_CHECK_EVERY_ROWS=2500
# For fastest COPY + transform use direct Postgres :5432 in DATABASE_URL (not pooler :6543).

# Bulk delete by bill_date: SET LOCAL statement_timeout = 0 inside the delete transaction (default 1).
# DATA_DELETE_RANGE_NO_STATEMENT_TIMEOUT=0
