PORT=5000

# Data access (use both for import / export / CRUD via API):
# - DATABASE_URL → Postgres pool (COPY, pivot SQL, bulk delete, etc.)
# - ANON_KEY → Supabase JS REST (same DB; masters, import_jobs, batched inserts when pooler, etc.)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpvZnlocG51dHJnamVleGt1bGNmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA5NzMzMzUsImV4cCI6MjA4NjU0OTMzNX0.aX0Lbte-quibB6xNMzFh-8_Oq4A3T_JS7uwInjZRTWo
# Optional if DATABASE_URL is Supabase (db.<ref>.supabase.co or pooler user postgres.<ref>); else set explicitly:
SUPABASE_URL=https://jofyhpnutrgjeexkulcf.supabase.co

NODE_ENV=development

# Auth: cache app_users lookups by email (speeds up repeat logins)
# AUTH_USER_CACHE_TTL_MS=600000

# Postgres URI (required for server-side SQL). Supabase: Settings → Database → URI.
# Direct db: ...db.<ref>.supabase.co:5432/postgres
# Pooler (PgBouncer, port 6543): import auto-uses batched Supabase inserts; COPY path prefers direct 5432.
# DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres
#
# TLS: by default SSL uses rejectUnauthorized=false (Supabase). Set DATABASE_SSL_STRICT=1 for strict verification.
# PG_POOL_MAX=15
# PG_CONNECTION_TIMEOUT_MS=30000

# Pivot GROUP BY / MV aggregation: per-statement timeout (ms).
# - Local dev default: 5000ms if NODE_ENV is not production.
# - Production-like default (NODE_ENV=production or RENDER=true, var unset): 180000ms (3 min).
# - Very large cubes: set PIVOT_PG_STATEMENT_TIMEOUT_MS=600000 (10 min) on Render Environment.
# PIVOT_PG_STATEMENT_TIMEOUT_MS=600000
# Optional alias: PIVOT_SLA_MS=600000
# DISTINCT filter dropdowns + drilldown SQL (default 180000 ms; keep ≤ frontend VITE_PIVOT_FILTER_TIMEOUT_MS)
# PIVOT_FILTER_SQL_TIMEOUT_MS=180000
#
# Large fact tables (1M+ rows): bigger hash aggregate + optional parallel workers (per pivot transaction only).
# PIVOT_PG_WORK_MEM=256MB
# PIVOT_PG_PARALLEL_WORKERS=4
# Row+column dimensions allowed for SQL pivot (default 18, max 32): PIVOT_MAX_GROUP_DIMENSIONS=18
# In-memory pivot result cache TTL (ms): PIVOT_MEMORY_CACHE_TTL_MS=180000

# Brand×State×Month materialized-view pivot only: skip second COUNT(*) on sales_data (default on). Exact total: PIVOT_PG_SKIP_FACT_ROW_COUNT=0
# PIVOT_PG_SKIP_FACT_ROW_COUNT=0

# Data tab: cache paginated JSON (default 45s); COUNT(*) cache (default 120s).
# Unfiltered list uses approximate total from pg stats (~instant). Force exact: GET ?exactTotal=1 or set:
# DATA_DISABLE_APPROX_COUNT=1
# DATA_PAGE_CACHE_TTL_MS=45000
# DATA_COUNT_CACHE_TTL_MS=120000

# Optional Redis: pivot body + filter DISTINCT lists (set REDIS_URL or REDISCLOUD_URL).
# PIVOT_REDIS_TTL_SEC=420
# PIVOT_FILTER_REDIS_TTL_SEC=900

# --- Large Excel import tuning (defaults tuned for high throughput) ---
# Import atomicity: default IMPORT_ATOMIC=1 uses one COPY (no partial rows on failure). Set IMPORT_ATOMIC=0 to allow parallel COPY (IMPORT_COPY_PARALLEL).
# IMPORT_ATOMIC=1
# Parallel CSV shard files / COPY streams (1–8, default 4; only if IMPORT_ATOMIC=0).
# IMPORT_COPY_PARALLEL=4
# Progress written to import_jobs at least every N rows during COPY (default 50000).
# IMPORT_JOB_UPDATE_EVERY_ROWS=50000
# Cancel flag checked every N data rows — not every row (default 2500).
# IMPORT_CANCEL_CHECK_EVERY_ROWS=2500
# For fastest COPY + transform use direct Postgres :5432 in DATABASE_URL (not pooler :6543).
# COPY/import sessions set statement_timeout=0 by default. If you set a cap, use ms (e.g. 600000). Supabase pooler can still enforce its own limits.
# IMPORT_STATEMENT_TIMEOUT_MS=0

# Bulk delete by bill_date: SET LOCAL statement_timeout = 0 inside the delete transaction (default 1).
# DATA_DELETE_RANGE_NO_STATEMENT_TIMEOUT=0
