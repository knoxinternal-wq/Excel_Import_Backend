PORT=5002
NODE_ENV=development

# Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Backward compatibility alias (optional if SUPABASE_SERVICE_ROLE_KEY is set)
# SERVICE_ROLE_KEY=your_service_role_key_here

# Postgres (Supabase direct or pooler URL)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Auth hardening (required in production)
AUTH_SESSION_SECRET=replace_with_a_long_random_secret
AUTH_TOKEN_TTL=12h
